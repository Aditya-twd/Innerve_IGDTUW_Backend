generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  admin
}

enum BuildingType {
  department
  hostel
}

enum ChatType {
  companion
  rant
  group
}

enum RiskLevel {
  low
  moderate
  high
}

model User {
  id            String   @id @default(uuid())
  role          Role     @default(student)
  email         String?  @unique
  password_hash String?
  college_id    String?
  department    String?
  hostel        String?
  year          Int?
  avatar        String?
  message_count Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  college        College?        @relation(fields: [college_id], references: [id])
  messages       Message[]
  emotionSignals EmotionSignal[]

  @@index([college_id])
}

model College {
  id               String   @id @default(uuid())
  name             String
  location         String?
  admin_id         String?
  counsellor_name  String?
  counsellor_phone String?
  counsellor_email String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  users          User[]
  buildings      Building[]
  messages       Message[]
  emotionSignals EmotionSignal[]
}

model Building {
  id         String       @id @default(uuid())
  college_id String
  name       String
  type       BuildingType
  x_position Float
  y_position Float
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  college        College          @relation(fields: [college_id], references: [id])
  messages       Message[]
  emotionSignals EmotionSignal[]
  stats          AggregatedStats?
}

model Message {
  id          String   @id @default(uuid())
  user_id     String
  college_id  String?
  building_id String?
  chat_type   ChatType
  text        String
  timestamp   DateTime @default(now())

  user     User      @relation(fields: [user_id], references: [id])
  building Building? @relation(fields: [building_id], references: [id])
  college  College?  @relation(fields: [college_id], references: [id])

  @@index([user_id])
  @@index([building_id])
  @@index([college_id])
}

model EmotionSignal {
  id          String    @id @default(uuid())
  user_id     String
  college_id  String
  building_id String
  stress      Float
  sadness     Float
  hope        Float
  topics      Json
  risk_level  RiskLevel
  timestamp   DateTime  @default(now())

  user     User     @relation(fields: [user_id], references: [id])
  building Building @relation(fields: [building_id], references: [id])
  college  College  @relation(fields: [college_id], references: [id])

  @@index([building_id])
  @@index([college_id])
}

model AggregatedStats {
  id                String   @id @default(uuid())
  building_id       String   @unique
  avg_stress        Float
  avg_sadness       Float
  avg_hope          Float
  top_topics        Json
  risk_distribution Json
  last_updated      DateTime @updatedAt

  building Building @relation(fields: [building_id], references: [id])
}
